{
  "name": "@openz/cli",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "openz": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts daemon restart",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:tts": "node -e \"import('@openz/speech/server').then(m=>{const k=process.env.OPENZ_TTS_APPKEY||'d098393c-32be-4b38-9814-c85da94dc6c6';const s=m.bidirectionTtsStream({appkey:k,resourceId:'seed-tts-2.0',voiceType:'saturn_zh_female_aojiaonvyou_tob',texts:['你好，测试流式合成。'],encoding:'pcm',sampleRate:24000});let f=0;s.on('data',c=>f++);s.on('end',()=>{console.log('PASS:',f,'frames');process.exit(0)});s.on('error',e=>{console.log('FAIL:',e.message);process.exit(1)})})\""
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.178",
    "@openz/shared": "workspace:*",
    "@openz/speech": "workspace:*",
    "dotenv": "^17.4.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "uuid": "^9.0.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
