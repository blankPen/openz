{
  "name": "openz",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @openz/server --filter @openz/cli --filter @openz/web run dev",
    "dev:server": "pnpm --filter @openz/server run dev",
    "dev:daemon": "pnpm --filter @openz/cli run dev",
    "dev:web": "pnpm --filter @openz/web run dev",
    "dev:mobile": "pnpm --filter @openz/mobile start",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r typecheck"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.178"
  }
}
